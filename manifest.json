{
  "manifest_version": 3,
  "name": "Bahria LMS Redesign",
  "version": "2.0",
  "description": "Modern UI redesign for Bahria University LMS and CMS — clean layout, dark mode, and multiple color themes.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "LMS Redesign Settings",
    "default_icon": {
      "16": "icons/logo.png",
      "48": "icons/logo.png",
      "128": "icons/logo.png"
    }
  },
  "icons": {
    "16": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://lms.bahria.edu.pk/*"],
      "css": ["css/mystyle.css"],
      "js": ["js/content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://cms.bahria.edu.pk/*"],
      "css": ["css/cms-style.css"],
      "js": ["js/cms-content.js"],
      "run_at": "document_start"
    }
  ]
}